# Rust
/target
**/*.rs.bk
Cargo.lock.orig

# Node / frontend
node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/dist/
.vite/

# Tauri build output
src-tauri/target/
src-tauri/gen/

