# Copy to `.env` (or export in your shell) to enable live content generation.
# Without a key, Glossa runs with the offline MockContentGenerator.

# Required for live generation.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the generation model. Defaults to claude-opus-4-8.
# For the high-volume reading loop you may prefer a cheaper/faster model, e.g.:
#   GLOSSA_MODEL=claude-haiku-4-5
# GLOSSA_MODEL=claude-opus-4-8
